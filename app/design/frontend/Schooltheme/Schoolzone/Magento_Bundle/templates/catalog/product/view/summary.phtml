<script>
require(['jquery'], function ($) {
    'use strict';

    function validateStudentFields() {
        let valid = true;

        const name = $('#student_pname').val().trim();
        const roll = $('#student_pid').length ? $('#student_pid').val().trim() : '';

        // Student Name
        if (name === '') {
            $('#student-name-error').show();
            valid = false;
        } else {
            $('#student-name-error').hide();
        }

        // Roll Number (if exists)
        if ($('#student_pid').length) {
            if (roll === '') {
                $('#student-id-error').show();
                valid = false;
            } else {
                $('#student-id-error').hide();
            }
        }

        return valid;
    }

    // Validate on typing & blur
    $('#student_pname, #student_pid').on('keyup blur', function () {
        validateStudentFields();
    });

    // Block Update Cart / Submit
    $('form').on('submit', function (e) {
        if (!validateStudentFields()) {
            e.preventDefault();
            return false;
        }
    });
});
</script>



