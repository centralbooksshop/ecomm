<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <typography>
            <base>
                <!--Default Config Base Fonts-->
                <ub_base_font_library_var>google</ub_base_font_library_var>
                <ub_base_google_font_name_var>Roboto</ub_base_google_font_name_var>
                <ub_font_face_weights_var>300,400,500,700</ub_font_face_weights_var>
