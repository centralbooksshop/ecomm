                    <ub_tablet_two_column_var>4</ub_tablet_two_column_var>
                    <ub_tablet_sm_two_column_var>3</ub_tablet_sm_two_column_var>
                    <ub_mobile_two_column_var>3</ub_mobile_two_column_var>
                    <ub_mobile_sm_two_column_var>2</ub_mobile_sm_two_column_var>
                </two_columns_layout>
            </grid>
            <list>
                <img_width>200</img_width>
                <img_height>300</img_height>
                <max_chars>320</max_chars>
            </list>
        </category_view>
        <product_view>
            <general>
                <update_layout>update_product_view__default</update_layout>
                <enable_author>1</enable_author>
            </general>
            <gallery>
                <general>
                    <image_medium_width>270</image_medium_width>
