                <logo>
                    <width_desktop>152</width_desktop>
                    <height_desktop>26</height_desktop>
                    <width_mobile>152</width_mobile>
                    <height_mobile>26</height_mobile>
                </logo>
            </header>
            <footer>
                <general>
                    <update_layout>update_footer_view__default</update_layout>
                </general>
            </footer>
        </element>
        <category_view>
            <general>
                <enable_author>1</enable_author>
                <ub_category_border_item_var>0</ub_category_border_item_var>
            </general>
            <grid>
                <image>
                    <img_width>240</img_width>
                    <img_height>360</img_height>
                </image>
                <one_column_layout>
                    <ub_desktop_one_column_var>6</ub_desktop_one_column_var>
