    echo '<link rel="stylesheet" type="text/css" href="'.trim($block->getViewFileUrl("css/source/skin/green.css")).'">';
  }elseif ($ubcolor == "violet") {
    echo '<link rel="stylesheet" type="text/css" href="'.trim($block->getViewFileUrl("css/source/skin/violet.css")).'">';
  }elseif ($ubcolor == "yellow") {
    echo '<link rel="stylesheet" type="text/css" href="'.trim($block->getViewFileUrl("css/source/skin/yellow.css")).'">';
  }elseif ($ubcolor == "xmas") {
    echo '<link rel="stylesheet" type="text/css" href="'.trim($block->getViewFileUrl("css/source/skin/xmas.css")).'">';
