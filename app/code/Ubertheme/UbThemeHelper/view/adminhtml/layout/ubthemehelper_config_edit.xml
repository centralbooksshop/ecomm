<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="admin-2columns-left" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="jquery/colorpicker/css/colorpicker.css"/>
        <css src="Ubertheme_Base::css/select2.min.css"/>
        <css src="Ubertheme_UbThemeHelper::css/edit.css"/>
    </head>
    <body>
        <referenceContainer name="js">
            <block class="Magento\Backend\Block\Template" template="Magento_Config::system/config/js.phtml"/>
            <block class="Magento\Backend\Block\Template" template="Ubertheme_UbThemeHelper::system/config/js.phtml"/>
        </referenceContainer>
        <referenceContainer name="left">
            <block class="Ubertheme\UbThemeHelper\Block\Adminhtml\Config\Tabs" name="adminhtml.system.config.tabs" before="-"/>
        </referenceContainer>
        <referenceContainer name="content">
            <block name="ubthemehelper.config.edit" class="Ubertheme\UbThemeHelper\Block\Adminhtml\Config\Edit"/>
        </referenceContainer>
    </body>
</page>
