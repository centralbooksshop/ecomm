<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="page.main.actions">
            <block class="Magento\Backend\Block\Store\Switcher"
                   name="adminhtml.system.config.switcher"
                   template="Magento_Backend::store/switcher.phtml">
                    <arguments>
                        <argument name="switch_websites" xsi:type="string">1</argument>
                        <argument name="switch_store_groups" xsi:type="string">0</argument>
                        <argument name="switch_store_views" xsi:type="string">1</argument>
                        <argument name="default_selection_name" xsi:type="string" translate="true">Default</argument>
                        <argument name="show_manage_stores_link" xsi:type="string">0</argument>
                    </arguments>
            </block>
            <block class="Magento\Backend\Block\Template" template="Ubertheme_UbThemeHelper::buttons.phtml"/>
        </referenceContainer>
        <referenceBlock name="page.title">
            <action method="setPageTitle">
                <argument translate="true" name="title" xsi:type="string">Themes Configuration</argument>
            </action>
        </referenceBlock>
        <referenceContainer name="content">
            <block class="Ubertheme\UbThemeHelper\Block\Adminhtml\ThemeList"
                   name="ubthemehelper.theme.list"
                   template="Ubertheme_UbThemeHelper::list.phtml"/>
        </referenceContainer>
    </body>
</page>
