<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <listingToolbar name="listing_top">
        <massaction name="listing_massaction">
            <action name="print_fedex_shipping_label">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="type" xsi:type="string">print_fedex_shipping_label</item>
                        <item name="label" xsi:type="string" translate="true">Print FedEx Shipping Labels</item>
                        <item name="url" xsi:type="url" path="infomodus_fedexlabel/pdflabels/many"/>
                    </item>
                </argument>
            </action>
            <action name="create_fedex_shipping_label">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="type" xsi:type="string">create_fedex_shipping_label</item>
                        <item name="label" xsi:type="string" translate="true">Create FedEx Shipping Labels</item>
                        <item name="url" xsi:type="url" path="infomodus_fedexlabel/items/bulk"/>
                    </item>
                </argument>
            </action>
        </massaction>
    </listingToolbar>
    <columns name="sales_order_shipment_columns">
        <actionsColumn name="fedexlabelstatus" class="Infomodus\Fedexlabel\Block\Adminhtml\Widget\Order\Grid\Column\Renderer\LabelsStatus">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="label" xsi:type="string" translate="true">FedEx Status</item>
                    <item name="sortable" xsi:type="boolean">false</item>
                    <item name="labelOS" xsi:type="string">shipment</item>
                    <item name="draggable" xsi:type="boolean">true</item>
                </item>
            </argument>
        </actionsColumn>
    </columns>
</listing>
