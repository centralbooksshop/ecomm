                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="default_return_amount" translate="label" type="text" sortOrder="400" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Order amount for default return label, from</label>
                </field>
                <field id="default_return_method" translate="label" type="select" sortOrder="500" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Default shipping method for return labels</label>
                    <source_model>Infomodus\Fedexlabel\Model\Config\Fedexmethod</source_model>
                </field>
                <field id="default_return_method_inter" translate="label" type="select" sortOrder="600" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Default shipping method for international return labels</label>
                    <source_model>Infomodus\Fedexlabel\Model\Config\InternationalFedexmethod</source_model>
                </field>
                <field id="packagingreference_type" translate="label comment" type="select" sortOrder="700" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Customer Reference Type</label>
                    <source_model>Infomodus\Fedexlabel\Model\Config\ReferenceTypeRefund</source_model>
                </field>
                <field id="packagingreferencenumbervalue" translate="label comment" type="text" sortOrder="710" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Customer Reference Value</label>
                </field>
            </group>
            <group id="weightdimension" translate="label" type="text" sortOrder="600" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Weight and Dimensions</label>
                <field id="weightunits" translate="label" type="select" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Weight units</label>
                    <source_model>Infomodus\Fedexlabel\Model\Config\Weight</source_model>
                </field>
                <field id="defweigth" translate="label" type="text" sortOrder="200" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Default weight</label>
                </field>
                <field id="packweight" translate="label" type="text" sortOrder="300" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Pack weight</label>
                </field>
                <field id="max_weight" translate="label" type="text" sortOrder="400" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Max weight of the package</label>
                </field>
                <field id="dimensions_type" translate="label" type="select" sortOrder="500" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Dimensions type</label>
                    <source_model>Infomodus\Fedexlabel\Model\Config\DimensionsType</source_model>
                </field>
                <field id="default_dimensions_box" translate="label" type="select" sortOrder="600" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Default box</label>
                    <source_model>Infomodus\Fedexlabel\Model\Config\Defaultdimensionsset</source_model>
                    <depends>
                        <field id="dimensions_type">1</field>
                    </depends>
                </field>
                <field id="unitofmeasurement" translate="label" type="select" sortOrder="700" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Default unit of dimensions</label>
                    <source_model>Infomodus\Fedexlabel\Model\Config\Unitofmeasurement</source_model>
                </field>
            </group>
            <group id="ratepayment" translate="label" type="text" sortOrder="700" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Rates and Payments</label>
                <field id="third_party" translate="label" type="select" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Payer</label>
                    <source_model>Infomodus\Fedexlabel\Model\Config\Methodofpayment</source_model>
                </field>
                <field id="currencycode" translate="label comment" type="select" sortOrder="200" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Default Currency code</label>
                    <source_model>Magento\Config\Model\Config\Source\Locale\Currency\All</source_model>
                    <comment>Required field</comment>
                    <validate>required-entry</validate>
                </field>
                <field id="cod" translate="label" type="select" sortOrder="500" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>COD (default)</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="cod_shipping_cost" translate="label" type="select" sortOrder="500" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Add shipping cost to COD</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="cod">1</field>
                    </depends>
                </field>
                <field id="insured_automaticaly" translate="label" type="select" sortOrder="550" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Add Insured Value automatically</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="dytytaxinternational" translate="label" type="select" sortOrder="600" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Payment Conditions of Duties and Taxes for International shipments</label>
                    <source_model>Infomodus\Fedexlabel\Model\Config\DutyAndTaxInternational</source_model>
                </field>
            </group>
            <group id="quantum" translate="label" type="text" sortOrder="800" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Notification</label>
                <field id="qvn" translate="label" type="select" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Notification Enable</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="qvn_code" translate="label" type="multiselect" sortOrder="200" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Notification Type</label>
                    <source_model>Infomodus\Fedexlabel\Model\Config\Notificationcode</source_model>
                </field>
                <field id="qvn_email_shipper" translate="label" type="text" sortOrder="300" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Shipper Email</label>
                </field>
                <field id="adult" translate="label" type="select" sortOrder="350" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Delivery Signature</label>
                    <source_model>Infomodus\Fedexlabel\Model\Config\DeliveryConfirmation</source_model>
                </field>
            </group>
            <group id="printing" translate="label" type="text" sortOrder="900" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Printing Settings</label>
                <field id="printer" translate="label comment" type="select" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Print Type</label>
                    <source_model>Infomodus\Fedexlabel\Model\Config\PrintType</source_model>
                </field>
                <field id="printer_name" translate="label" type="text" sortOrder="150" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Name of printer</label>
                    <validate>required-entry</validate>
                    <comment>If you use more than one printer, enter them separated by commas</comment>
                    <depends>
                        <field separator="|" id="printer" negative="1">pdf|png</field>
                    </depends>
                </field>
                <field id="automatic_printing" translate="label comment" type="select" sortOrder="160" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Automatic printing</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field separator="|" id="printer" negative="1">pdf|png</field>
                    </depends>
                </field>
                <field id="automatic_printing_ip" translate="label comment" type="text" sortOrder="170" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>IP</label>
                    <depends>
                        <field separator="|" id="printer" negative="1">pdf|png</field>
                    </depends>
                </field>
                <field id="automatic_printing_port" translate="label comment" type="text" sortOrder="180" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Port</label>
                    <depends>
                        <field separator="|" id="printer" negative="1">pdf|png</field>
                    </depends>
                </field>
                <field id="printer_format_pdf" translate="label comment" type="select" sortOrder="200" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Format</label>
                    <source_model>Infomodus\Fedexlabel\Model\Config\PrintFormatPdf</source_model>
                    <depends>
                        <field separator="|" id="printer">pdf|png</field>
                    </depends>
                </field>
                <field id="printer_format_thermal" translate="label comment" type="select" sortOrder="200" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Format</label>
                    <source_model>Infomodus\Fedexlabel\Model\Config\PrintFormatThermal</source_model>
                    <depends>
                        <field separator="|" id="printer" negative="1">pdf|png</field>
                    </depends>
                </field>
                <field id="bulk_printing_all" translate="label comment" type="select" sortOrder="300" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Bulk printing</label>
                    <source_model>Infomodus\Fedexlabel\Model\Config\BulkPrinting</source_model>
                </field>
                <field id="copies" translate="label comment" type="text" sortOrder="400" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Copies</label>
                    <depends>
                        <field separator="|" id="printer">pdf|png</field>
                    </depends>
                </field>
            </group>
