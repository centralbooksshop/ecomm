                    <comment>Required field</comment>
                    <validate>required-entry</validate>
                </field>
                <field id="shippernumber" translate="label comment" type="password" sortOrder="400" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Account ID</label>
                    <comment>Required field</comment>
                    <validate>required-entry</validate>
                </field>
                <field id="meter_number" translate="label comment" type="password" sortOrder="500" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Meter Number</label>
                    <comment>Required field</comment>
                    <validate>required-entry</validate>
