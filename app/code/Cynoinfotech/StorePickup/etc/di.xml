<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <!-- create virtualType StorePickUpGridDataProvider -->
    
    <virtualType name="StorePickUpGridDataProvider" type="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider">
        <arguments>
            <argument name="collection" xsi:type="object" shared="false">Cynoinfotech\StorePickup\Model\ResourceModel\StorePickup\Collection</argument>
            <argument name="filterpool" xsi:type="object" shared="false"> StorePickUpGridFilterPool</argument>
        </arguments>
    </virtualType>
	
	<!-- create virtualType StorePickUpGridDataProvider -->
    
    <!-- create StorePickUpGridFilterPool -->
    
    <virtualType name="StorePickUpGridFilterPool" type="Magento\Framework\View\Element\UiComponent\DataProvider\FilterPool">
        <arguments>
            <argument name="appliers" xsi:type="array">
                <item name="regular" xsi:type="object">Magento\Framework\View\Element\UiComponent\DataProvider\RegularFilter</item>
                <item name="fulltext" xsi:type="object">Magento\Framework\View\Element\UiComponent\DataProvider\FulltextFilter</item>
            </argument>
        </arguments>
    </virtualType>
    
    <!-- type for storepickup_listing_data_source -->
    <type name="Magento\Framework\View\Element\UiComponent\DataProvider\CollectionFactory">
        <arguments>
            <argument name="collections" xsi:type="array">
                <item name="storepickup_listing_data_source" xsi:type="string">Cynoinfotech\StorePickup\Model\ResourceModel\StorePickup\Grid\Collection</item>
            </argument>
        </arguments>
    </type>
    
    <!-- simulate Cynoinfotech\StorePickup\Model\ResourceModel\StorePickup\Grid\Collection -->
    <virtualType name="Cynoinfotech\StorePickup\Model\ResourceModel\StorePickup\Grid\Collection" type ="Magento\Framework\View\Element\UiComponent\DataProvider\SearchResult">
        <arguments>
            <argument name="mainTable" xsi:type="string">ci_stores</argument>
			<argument name="eventPrefix" xsi:type="string">storepickup_grid_collection</argument>
            <argument name="eventObject" xsi:type="string">storepickup_grid_collection</argument>
            <argument name="resourceModel" xsi:type="string">Cynoinfotech\StorePickup\Model\ResourceModel\StorePickup\Collection</argument>
        </arguments>
    </virtualType>

    <!-- create virtualType StorePickUpOrderGridDataProvider -->
    
    <virtualType name="StorePickUpOrderGridDataProvider" type="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider">
        <arguments>
            <argument name="collection" xsi:type="object" shared="false">Cynoinfotech\StorePickup\Model\ResourceModel\StorePickupOrder\Collection</argument>
            <argument name="filterpool" xsi:type="object" shared="false"> StorePickUpOrderGridFilterPool</argument>
        </arguments>
    </virtualType>
	
	<!-- create virtualType StorePickUpOrderGridDataProvider -->
    
    <!-- create StorePickUpGridFilterPool -->
    
    <virtualType name="StorePickUpOrderGridFilterPool" type="Magento\Framework\View\Element\UiComponent\DataProvider\FilterPool">
        <arguments>
            <argument name="appliers" xsi:type="array">
                <item name="regular" xsi:type="object">Magento\Framework\View\Element\UiComponent\DataProvider\RegularFilter</item>
                <item name="fulltext" xsi:type="object">Magento\Framework\View\Element\UiComponent\DataProvider\FulltextFilter</item>
            </argument>
        </arguments>
    </virtualType>
    
    <!-- type for storepickuporder_listing_data_source -->
    <type name="Magento\Framework\View\Element\UiComponent\DataProvider\CollectionFactory">
        <arguments>
            <argument name="collections" xsi:type="array">
                <item name="storepickuporder_listing_data_source" xsi:type="string">Cynoinfotech\StorePickup\Model\ResourceModel\StorePickupOrder\Grid\Collection</item>
            </argument>
        </arguments>
    </type>
    
    <!-- simulate Cynoinfotech\StorePickup\Model\ResourceModel\StorePickupOrder\Grid\Collection -->
    <virtualType name="Cynoinfotech\StorePickup\Model\ResourceModel\StorePickupOrder\Grid\Collection" type ="Magento\Framework\View\Element\UiComponent\DataProvider\SearchResult">
        <arguments>
            <argument name="mainTable" xsi:type="string">ci_stores_order</argument>
			<argument name="eventPrefix" xsi:type="string">storepickuporder_grid_collection</argument>
            <argument name="eventObject" xsi:type="string">storepickuporder_grid_collection</argument>
            <argument name="resourceModel" xsi:type="string">Cynoinfotech\StorePickup\Model\ResourceModel\StorePickupOrder\Collection</argument>
        </arguments>
    </virtualType>
	
	<!-- plugin for shipping information -->
	<type name="Magento\Checkout\Model\ShippingInformationManagement">
        <plugin name="save-in-quote" type="Cynoinfotech\StorePickup\Plugin\Checkout\ShippingInformationManagement"/>
    </type>
	
	<!-- order save plugin -->
    <!-- <type name="Magento\Sales\Api\OrderRepositoryInterface">
        <plugin name="CiSaveOrder" type="Cynoinfotech\StorePickup\Plugin\Order\OrderSave"/>
    </type> -->    
	
