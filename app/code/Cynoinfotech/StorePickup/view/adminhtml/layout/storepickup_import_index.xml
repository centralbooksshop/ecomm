<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="admin-2columns-left" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="menu">
			<action method='setActive'>
				<argument name='itemId' xsi:type='string'>Cynoinfotech_StorePickup::storepickup</argument>
			</action>
		</referenceBlock>
		 <referenceBlock name="page.title">
            <action method="setTitleClass">
                <argument name="class" xsi:type="string">complex</argument>
            </action>
        </referenceBlock>
        <referenceContainer name="content">
            <block class="Cynoinfotech\StorePickup\Block\Adminhtml\Import\Edit" name="Cynoinfotech_storepickup_import_edit"/>
            <!-- <block class="Magento\Backend\Block\Template" name="import-js" template="Cynoinfotech_StorePickup::import-js.phtml" /> -->
        </referenceContainer>
        <referenceContainer name="left">
            <block class="Cynoinfotech\StorePickup\Block\Adminhtml\Import\Edit\Tabs" name="import_tabs">
                <block class="Cynoinfotech\StorePickup\Block\Adminhtml\Import\Edit\Tab\Import" name="Cynoinfotech_storepickup_import_edit_tab_import"/>
                <action method="addTab">
                    <argument name="name" xsi:type="string">import</argument>
                    <argument name="block" xsi:type="string">Cynoinfotech_storepickup_import_edit_tab_import</argument>
                </action>
            </block>
        </referenceContainer>
    </body>
</page>    