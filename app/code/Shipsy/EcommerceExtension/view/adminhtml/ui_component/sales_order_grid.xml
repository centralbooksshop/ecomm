<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <listingToolbar name="listing_top">
            <massaction name="listing_massaction">
               <action name="softdatasync">
					<settings>
						<url path="softdatasync/softdatashipsy/formdata"/>
						<type>softdata_sync_shipsy</type>
						<label translate="true">Ship with DTDC</label>
					</settings>
				</action>

                <action name="manageorders">
                    <settings>
                        <url path="softdatasync/order/details"/>
                        <type>manage_orders_shipsy</type>
                        <label translate="true">Manage DTDC orders</label>
                    </settings>
                </action>
                <action name="addtracking">
                    <settings>
                        <url path="softdatasync/order/tracking"/>
                        <type>add_tracking_shipsy</type>
                        <label translate="true">Add DTDC Tracking</label>
                    </settings>
                </action>
                <!-- <action name="bulklabelprint">
