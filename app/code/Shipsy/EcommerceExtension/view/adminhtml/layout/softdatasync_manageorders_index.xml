<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="admin-1column" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <link rel="stylesheet" type="text/css" src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" src_type="url"/>
        <css src="Shipsy_EcommerceExtension::css/custom.css"/>
    </head>
    <referenceBlock name="page.title">
        <action method="setPageTitle">
            <argument name="title" xsi:type="string">Manage Orders</argument>
        </action>
    </referenceBlock>
    <body>
        <referenceContainer name="content">
            <block class="Shipsy\EcommerceExtension\Block\Manage" name="softdatasync.manage.index" template="Shipsy_EcommerceExtension::manageorders.phtml" />
        </referenceContainer>
    </body>
</page>