<?xml version="1.0"?>
<!--
    Create table: service_types
-->
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <table name="service_types" resource="default" engine="innodb" comment="Service Types Master Table">
        
        <!-- Primary key -->
        <column xsi:type="int" name="entity_id" nullable="false" identity="true" unsigned="true" comment="Entity ID"/>
        
        <!-- Service ID (like 'AIR', 'DTDC AIR MAX', etc.) -->
        <column xsi:type="varchar" name="service_code" nullable="false" length="255" comment="Service Code"/>
        
        <!-- Service display name -->
        <column xsi:type="varchar" name="name" nullable="false" length="255" comment="Service Name"/>
        
        <!-- Active flag -->
        <column xsi:type="smallint" name="active" nullable="false" default="1" comment="Is Active (1=Yes, 0=No)"/>
        
        <!-- Default flag -->
        <column xsi:type="smallint" name="is_default" nullable="false" default="0" comment="Is Default (1=Yes, 0=No)"/>

        <!-- Timestamps -->
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Updated At"/>

        <!-- Primary Key -->
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>

        <!-- Index for service_code -->
        <index referenceId="SERVICE_TYPES_CODE_IDX">
            <column name="service_code"/>
        </index>

    </table>

</schema>
