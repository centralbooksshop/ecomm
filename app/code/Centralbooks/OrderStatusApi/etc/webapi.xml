<?xml version="1.0"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">

    <route url="/V1/order/update-status" method="POST">
        <service class="Centralbooks\OrderStatusApi\Api\OrderStatusInterface" method="checkAndUpdate"/>
        <resources>
           <resource ref="Magento_Sales::sales"/>
        </resources>
    </route>

	<route url="/V1/order/check-status" method="POST">
        <service class="Centralbooks\OrderStatusApi\Api\OrderStatusInterface" method="updateOrderStatus"/>
        <resources>
            <resource ref="Magento_Sales::sales"/>
        </resources>
    </route>

</routes>

