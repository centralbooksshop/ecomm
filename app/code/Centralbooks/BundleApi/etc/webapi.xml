<?xml version="1.0" ?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">
        <route url="/V1/custom/bundle/delete-child" method="POST">
                <service class="Centralbooks\BundleApi\Api\BundleDeleteManagementInterface" method="deleteChild"/>
                <resources>
                    <resource ref="Magento_Catalog::products"/>
                </resources>
	</route>
	
	<route url="/V1/custom/bundle/update-group-name" method="POST">
	    <service class="Centralbooks\BundleApi\Api\BundleUpdateManagementInterface" method="updateGroupName"/>
	    <resources>
	        <resource ref="Magento_Catalog::products"/>
	    </resources>
	</route>

</routes>
