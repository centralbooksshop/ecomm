<?xml version="1.0" ?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
	<table name="centralbooks_locationcode_locationcode" resource="default" engine="innodb" comment="centralbooks_locationcode_locationcode Table">
		<column xsi:type="int" name="locationcode_id" padding="10" unsigned="true" nullable="false" identity="true" comment="Entity Id"/>
		<constraint xsi:type="primary" referenceId="PRIMARY">
			<column name="locationcode_id"/>
		</constraint>
		<column name="location_name" nullable="true" xsi:type="text" comment="location name"/>
		<column xsi:type="varchar" name="location_code" nullable="true" length="255" comment="location Code"/>
		<column xsi:type="smallint" name="location_status" padding="10" unsigned="false" nullable="false" identity="false" default="0" comment="location status"/>
		<column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Creation Time"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Updation Time"/>
	</table>
</schema>
