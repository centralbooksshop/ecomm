<?xml version="1.0" ?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
	<argument name="data" xsi:type="array">
		<item name="js_config" xsi:type="array">
			<item name="provider" xsi:type="string">zones_addzone_form.zones_form_data_source</item>
		</item>
		<item name="label" xsi:type="string" translate="true">Zone Information</item>
		<item name="template" xsi:type="string">templates/form/collapsible</item>
	</argument>
	<settings>
		<buttons>
			<button name="back" class="Centralbooks\Zones\Block\Adminhtml\Addzone\Edit\BackButton"/>
			<button name="delete" class="Centralbooks\Zones\Block\Adminhtml\Addzone\Edit\DeleteButton"/>
			<button name="save" class="Centralbooks\Zones\Block\Adminhtml\Addzone\Edit\SaveButton"/>
			<button name="save_and_continue" class="Centralbooks\Zones\Block\Adminhtml\Addzone\Edit\SaveAndContinueButton"/>
		</buttons>
		<namespace>zones_addzone_form</namespace>
		<dataScope>data</dataScope>
		<deps>
			<dep>zones_addzone_form.zones_form_data_source</dep>
		</deps>
	</settings>
	<dataSource name="zones_form_data_source">
		<argument name="data" xsi:type="array">
			<item name="js_config" xsi:type="array">
				<item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
			</item>
		</argument>
		<settings>
			<submitUrl path="*/*/save"/>
		</settings>
		<dataProvider name="zones_form_data_source" class="Centralbooks\Zones\Model\Addzone\DataProvider">
			<settings>
				<requestFieldName>zones_id</requestFieldName>
				<primaryFieldName>zones_id</primaryFieldName>
			</settings>
		</dataProvider>
	</dataSource>
	<fieldset name="general">
		<settings>
			<label>Add Zone Information</label>
		</settings>

		<field name="zonelabel" formElement="input" sortOrder="9">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">Zones</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">Zone label</label>
				<dataScope>zonelabel</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">false</rule>
				</validation>
			</settings>
		</field>

		<field name="zonevalue" formElement="input" sortOrder="10">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">Zones</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">Zone Value</label>
				<dataScope>zonevalue</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">true</rule>
				</validation>
			</settings>
		</field>

	</fieldset>
</form>
