<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="styles"/>
    <body>
        <referenceContainer name="content">
            <block class="Centralbooks\OrderSchoolDashboards\Block\Adminhtml\HODashboard\Grid" name="centralbooks_orders_grid">
                <block class="Centralbooks\OrderSchoolDashboards\Block\Adminhtml\HODashboard\OrdersFilter" name="centralbooks_orders_grid.grid" as="grid">
                    <arguments>
                        <argument name="id" xsi:type="string">entity_id</argument>
                        <argument name="dataSource" xsi:type="object">Magento\Sales\Model\ResourceModel\Order\Collection</argument>
                        <argument name="default_sort" xsi:type="string">id</argument>
                        <argument name="default_dir" xsi:type="string">ASC</argument>
                        <argument name="save_parameters_in_session" xsi:type="string">1</argument>
                    </arguments>
                    <block class="Magento\Backend\Block\Widget\Grid\ColumnSet" name="centralbooks_orders_grid.grid.columnSet" as="grid.columnSet">
                        <arguments>
                            <argument name="rowUrl" xsi:type="array">
                                <item name="path" xsi:type="string">sales/order/view/</item>
                                <item name="extraParamsTemplate" xsi:type="array">   
                                    <item name="order_id" xsi:type="string">getEntityId</item>
                                </item>
                            </argument>
                        </arguments>
                        <block class="Magento\Backend\Block\Widget\Grid\Column" as="entity_id">
                            <arguments>
                                <argument name="header" xsi:type="string" translate="true">ID</argument>
                                <argument name="index" xsi:type="string">entity_id</argument>
                                <argument name="type" xsi:type="string">text</argument>
                                <argument name="column_css_class" xsi:type="string">col-id</argument>
                                <argument name="header_css_class" xsi:type="string">col-id</argument>
                            </arguments>
                        </block>
                        <block class="Magento\Backend\Block\Widget\Grid\Column" as="increment_id">
                            <arguments>
                                <argument name="header" xsi:type="string" translate="true">Increment Id</argument>
                                <argument name="index" xsi:type="string">increment_id</argument>
                                <argument name="type" xsi:type="string">text</argument>
                                <argument name="column_css_class" xsi:type="string">col-id</argument>
                                <argument name="header_css_class" xsi:type="string">col-id</argument>
                            </arguments>
                        </block>
                        <block class="Magento\Backend\Block\Widget\Grid\Column" as="created_at">
                            <arguments>
                                <argument name="header" xsi:type="string" translate="true">Created</argument>
                                <argument name="index" xsi:type="string">created_at</argument>
                                <argument name="type" xsi:type="string">date</argument>
                                <argument name="column_css_class" xsi:type="string">col-id</argument>
                                <argument name="header_css_class" xsi:type="string">col-id</argument>
                            </arguments>
                        </block>
                        <block class="Magento\Backend\Block\Widget\Grid\Column" as="payment_method">
                            <arguments>
                                <argument name="header" xsi:type="string" translate="true">Payment Method</argument>
                                <argument name="index" xsi:type="string">entity_id</argument>
                                <argument name="type" xsi:type="string">text</argument>
                                <argument name="column_css_class" xsi:type="string">col-id</argument>
                                <argument name="header_css_class" xsi:type="string">col-id</argument>
                                <argument name="renderer" xsi:type="string">Centralbooks\OrderSchoolDashboards\Block\Adminhtml\HODashboard\Renderer\PaymentMethod</argument>
                            </arguments>
                        </block>
                        <block class="Magento\Backend\Block\Widget\Grid\Column" as="shipping_description">
                            <arguments>
                                <argument name="header" xsi:type="string" translate="true">Shipping method</argument>
                                <argument name="index" xsi:type="string">shipping_description</argument>
                                <argument name="type" xsi:type="string">text</argument>
                                <argument name="column_css_class" xsi:type="string">col-id</argument>
                                <argument name="header_css_class" xsi:type="string">col-id</argument>
                            </arguments>
                        </block>
                    </block>
                </block>
            </block>
        </referenceContainer>
    </body>
</page>