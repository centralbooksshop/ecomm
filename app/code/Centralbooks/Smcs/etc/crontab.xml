<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="smcs_refresh_token"
             instance="Centralbooks\Smcs\Cron\RefreshToken"
             method="execute">
            <schedule>55 23 * * *</schedule>
        </job>
    </group>
	<group id="default">
		<job name="centralbooks_smcs_update_status"
			 instance="Centralbooks\Smcs\Cron\UpdateOrderStatus"
			 method="execute">
			<schedule>0 */2 * * *</schedule>
		</job>
	</group>
</config>