<?xml version="1.0" ?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="cbo_orders_payment_sync_reports" resource="default" engine="innodb" comment="Orders Payment Sync Report">
        <column xsi:type="smallint" name="id" padding="6" unsigned="true" nullable="false" identity="true" comment="Id"/>
        <column xsi:type="varchar" name="content" nullable="true" comment="Content"/>
        <column xsi:type="varchar" name="created_at" nullable="false" length="100" comment="Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
    </table>
    <table name="sales_order">
        <column xsi:type="varchar" name="payment_status" nullable="true" length="255" comment="Payment Status" />
    </table>
</schema>
