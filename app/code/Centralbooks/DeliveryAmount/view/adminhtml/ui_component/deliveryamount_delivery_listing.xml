<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
         <item name="provider" xsi:type="string">deliveryamount_delivery_listing.deliveryamount_delivery_listing_data_source</item>
            <item name="deps" xsi:type="string">deliveryamount_delivery_listing.deliveryamount_delivery_listing_data_source</item>
        </item>
        <item name="spinner" xsi:type="string">spinner_columns</item>
       
	<item name="buttons" xsi:type="array">
            <item name="update" xsi:type="array">
                <item name="name" xsi:type="string">update</item>
		<item name="label" xsi:type="string" translate="true">Import/Update Data</item>
                <item name="class" xsi:type="string">primary</item>
                <item name="url" xsi:type="string">*/*/update</item>
	    </item>
	</item>

    </argument>
    <dataSource name="centralbooks_deliveryamount_amount_listing_data_source">
        <argument name="dataProvider" xsi:type="configurableObject">
            <argument name="class" xsi:type="string">Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider</argument>
            <argument name="name" xsi:type="string">deliveryamount_delivery_listing_data_source</argument>
            <argument name="primaryFieldName" xsi:type="string">zones_id</argument>
            <argument name="requestFieldName" xsi:type="string">id</argument>
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="component" xsi:type="string">Magento_Ui/js/grid/provider</item>
                    <item name="update_url" xsi:type="url" path="mui/index/render"/>
                    <item name="storageConfig" xsi:type="array">
                        <item name="indexField" xsi:type="string">zones_id</item>
                    </item>
                </item>
            </argument>
        </argument>
    </dataSource>
    <columns name="spinner_columns">
