         <column name="zone_list">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Zone List</item>
                </item>
            </argument>
        </column>
       
        <column name="package_type">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Package Type</item>
                </item>
            </argument>
        </column>

        <column name="delivery_amount">
		<argument name="data" xsi:type="array">
		  <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Delivery Amount</item>
		    </item>
