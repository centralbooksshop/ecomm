<script>
 function toggleBundle(classId) {
  document.querySelectorAll('.bundle-container').forEach(e => e.style.display = 'none');
  const target = document.getElementById(classId);
  if (target) {
    target.style.display = 'block';
 } 
 }

 function toggleBooks(bundleId) {
  document.querySelectorAll('.book-container').forEach(e => e.style.display = 'none');
  const target = document.getElementById(bundleId);
  if (target) {
    target.style.display = 'block';
  }
}
</script>

