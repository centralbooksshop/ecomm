<?php
/** @var \SchoolZone\Review\Block\Display $block */
$schoolName = urldecode($this->getRequest()->getParam('schoolname'));
$classCollection = $block->getClass($schoolName);
$schoolImage = $block->getImage($schoolName);
?>
<div class = "alert">
<h2><?= $schoolName ?></h2>
</div>
<div id="class-list">
    <?php foreach ($classCollection as $key => $value) {
        $classId = strtolower(str_replace(' ', '', $value['label'])); // e.g., Class 1 => class1
    ?>
        <div class="class-card" onclick="toggleBundle('<?= $classId ?>')">
            <?= $value['label'] ?>
        </div>
    <?php } ?>
</div>

<?php foreach ($classCollection as $key => $value) {
    $classLabel = $value['label'];
    $classId = strtolower(str_replace(' ', '', $classLabel));
    $productsByClass = $block->getProductsByClass($schoolName, $value);

    $printedBundles = []; 
?>
    <div id="<?= $classId ?>" class="bundle-container">
        <?php foreach ($productsByClass as $bundle) {
            foreach ($bundle['data'] as $bundleItem) {
		    $bundleName = $bundleItem['options'];
		    $bundleId = $bundleItem['entity_id'];
                if (in_array($bundleName, $printedBundles)) {
                    continue;
                }
		$printedBundles[] = $bundleName;
         ?>
                <div class="bundle-card" onclick="toggleBooks('bundle_<?= $bundleId ?>')">
                    <?= $bundleName ?>
		</div>
		
		<div id="bundle_<?= $bundleId ?>" class="book-container">
		<table class="book-table">
            <tr class="table-header">
                <th>Image</th>
                <th>Book Name</th>
                <th>Qty</th>
                <th>Unit Price (MRP)</th>
                <th>Total</th>
	    </tr>
	    <?php
                $groupedBooks = $block->getBooksByBundleId($bundleId);
                $grandTotal = 0;
		foreach ($groupedBooks as $groupTitle => $books) {
			echo "<tr class='group-title'><td colspan='5'>{$groupTitle}</td></tr>";
			foreach ($books as $book) {
	                    $grandTotal += $book['total'];
	    ?>
		<tr class="book-row">
		    <td><img src="<?= $book['image_url'] ?>" class="product-img" /></td>
                    <td><?= $book['name'] ?></td>
                    <td><?= $book['qty'] ?></td>
                    <td>₹<?= number_format($book['price'], 2) ?></td>
		    <td>₹<?= number_format($book['total'], 2) ?></td>
                </tr>
            <?php } } ?>
	<tr style="background: #f0f0f0; font-weight: bold;">
                <td colspan="4" style="text-align: right;">Total Sale Price:</td>
                <td style="color: red;">₹<?= number_format($grandTotal, 2) ?></td>
            </tr>

        </table>
                </div>
        <?php } } ?>
    </div>
<?php } ?>


