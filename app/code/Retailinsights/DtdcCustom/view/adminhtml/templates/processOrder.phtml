$persistor->clear('multi_courier_upload');
?>

<?php if (!empty($uploadMessages)): ?>
    <div class="import-result">
        <h3>CSV Import Result</h3>
        <?php foreach ($uploadMessages as $msg): ?>
            <div class="import-line"><?= $msg ?></div>
        <?php endforeach; ?>
    </div>
<?php endif; ?>

<script>
require(['jquery'], function($){
    'use strict';

    var scannedSet = {};
    var currentCourier = '';

    function toArray(str){
        if(!str) return [];
        return $.map(str.split(','), function(s){ return $.trim(s); }).filter(function(s){ return s.length; });
    }

    function resetUI(){
		scannedSet = {};
		$('#scannedList, #orderListStatus, #readyToSubmit, #duplicate, #manualSummaryBox').empty();
		$('#order_count, #order_count_success').text('0');
		$('#divAssignBtn, #order_count_box, #order_count_box_success, #selectAllWrapper, #manualSummaryBox').hide();
		$('#selectAllOrders').prop('checked', false);
	}

    $('#selectCourier').on('change', function(){
        currentCourier = $(this).val() || '';
        resetUI();
        $('#courierLabel').text(
            currentCourier ? $('#selectCourier option:selected').text() + ' Order Number' : 'Order Number'
        );
        $('#csvCourier').val(currentCourier);
    });

    /** Add Order */
    $('#btnAddOrderId').on('click', function(){
		if(!currentCourier){ 
			alert('Please select courier first'); 
			return; 
		}

		var raw = $('#txtOrderId').val();
		if(!raw){ 
			alert('Please provide a valid order id'); 
			return; 
		}

		var toAdd = toArray(raw), uniqueNew = [];

		$.each(toAdd, function(i, id){
			if(!scannedSet[id]){ 
				scannedSet[id] = true; 
				uniqueNew.push(id); 
			}
		});

		if(uniqueNew.length === 0){ 
			alert('Order ID already scanned'); 
			return; 
		}

		// Show scanned list
		$('#scannedList').text(Object.keys(scannedSet).join(','));

		// CLEAR OLD UI BEFORE REBUILDING
		$('#orderListStatus').html('');
		$('#readyToSubmit').html('');
		$('#manualSummaryBox').hide().html('');
		$('#divAssignBtn, #order_count_box, #selectAllWrapper').hide();
		$('#selectAllOrders').prop('checked', false);

		// SEND ALL SCANNED ORDERS, NOT JUST NEW ONES
		var allOrders = Object.keys(scannedSet);

		checkShipment(allOrders, currentCourier, function(resultObj){
			var assignable = 0;

			if (resultObj._summary) {
				$('#manualSummaryBox').html(
					'Total Orders: ' + resultObj._summary.total +
					' | Assign Success: <span style="color:green;">' + resultObj._summary.success + '</span>' +
					' | Assign Failed: <span style="color:red;">' + resultObj._summary.failed + '</span>'
				).show();
			}

			$.each(resultObj, function(orderId, res){
				if(orderId === '_summary') return;

				if(res.status === 'success'){
					assignable++;
					$('#orderListStatus').append(
						'<label style="color:green;font-weight:bold;">' +
						'<input type="checkbox" class="group" value="'+orderId+'" checked> ' +
						orderId + ' : ' + res.message +
						'</label><br/>'
					);
				} else {
					$('#readyToSubmit').append(
						'<div style="color:red;font-weight:bold;">' +
						orderId + ' : ' + res.message +
						'</div>'
					);
				}
			});

			if(assignable > 0){
				$('#divAssignBtn, #order_count_box, #selectAllWrapper').show();
				$('#order_count').text($('#orderListStatus input.group:checked').length);
			}
		});

		$('#txtOrderId').val('');
	});

    /** Select All / Deselect All */
    $(document).on('change', '#selectAllOrders', function(){
        var checked = $(this).prop('checked');
        $('#orderListStatus input.group').prop('checked', checked);
        $('#order_count').text(checked ? $('#orderListStatus input.group').length : 0);
    });

    /** Individual checkbox update */
    $(document).on('change', '#orderListStatus input.group', function(){
        var total = $('#orderListStatus input.group').length;
        var checked = $('#orderListStatus input.group:checked').length;
        $('#order_count').text(checked);
        $('#selectAllOrders').prop('checked', total === checked);
    });

    function checkShipment(orderArray, courier, cb){
        $.ajax({
            url: '<?= $checkShipmentEndpoint ?>',
            type: 'POST',
            data: { orderIds: orderArray, courier: courier },
            dataType: 'json',
            complete: function(response){
                if(typeof cb === 'function') cb(response.responseJSON || {});
            }
        });
    }

    /** Submit **/
        $('.assignCourierBtn').on('click', function(){
			if(!currentCourier){ 
				alert('Please select courier'); 
				return; 
			}

			var selected = [];
			$('#orderListStatus input.group:checked').each(function(){ 
				selected.push($(this).val()); 
			});

			if(selected.length === 0){ 
				alert('Please select orders'); 
				return; 
			}

			$('#readyToSubmit').html('');
			$('#manualSummaryBox').hide().html('');

			$.ajax({
				url: '<?= $assignCourierEndpoint ?>',
				type: 'POST',
				data: { orderIds: selected, courier: currentCourier },
				dataType: 'json',
				complete: function(resp){
					var result = resp.responseJSON || {};
					var successCount = 0, failedCount = 0, total = 0;

					$.each(result, function(orderId, res){
						total++;

						if(res.status === 'success'){
							successCount++;
							$('#readyToSubmit').append(
								'<div style="color:green;font-weight:bold;">' +
								orderId + ' : ' + (res.message || 'Assigned successfully') +
								'</div>'
							);
						} else {
							failedCount++;
							$('#readyToSubmit').append(
								'<div style="color:red;font-weight:bold;">' +
								orderId + ' : ' + (res.message || 'Assignment failed') +
								'</div>'
							);
						}
					});

					$('#manualSummaryBox').html(
						'Total Orders: ' + total +
						' | Assign Success: <span style="color:green;">' + successCount + '</span>' +
						' | Assign Failed: <span style="color:red;">' + failedCount + '</span>'
					).show();

					$('#order_count_box_success').show();
					$('#order_count_success').text(successCount);

					$('#divAssignBtn').hide();
				}
			});
		});

    /**$('#csvImportForm').on('submit', function(e){
        if(!$('#selectCourier').val()){
            alert('Please select courier before importing CSV');
            e.preventDefault();
        }
    });*/
});
</script>

