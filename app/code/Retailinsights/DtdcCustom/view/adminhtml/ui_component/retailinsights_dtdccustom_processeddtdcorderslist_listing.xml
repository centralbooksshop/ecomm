<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd"
         name="retailinsights_dtdccustom_processeddtdcorderslist_listing">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">
                retailinsights_dtdccustom_processeddtdcorderslist_listing.retailinsights_dtdccustom_processeddtdcorderslist_listing_data_source
            </item>
            <item name="deps" xsi:type="string">
                retailinsights_dtdccustom_processeddtdcorderslist_listing.retailinsights_dtdccustom_processeddtdcorderslist_listing_data_source
            </item>
        </item>
        <item name="spinner" xsi:type="string">retailinsights_dtdccustom_processeddtdcorderslist_columns</item>
    </argument>

    <!-- DataSource -->
    <dataSource name="retailinsights_dtdccustom_processeddtdcorderslist_listing_data_source"
                component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>

        <dataProvider name="retailinsights_dtdccustom_processeddtdcorderslist_listing_data_source"
                      class="Retailinsights\DtdcCustom\Model\DataProvider">
            <settings>
                <primaryFieldName>id</primaryFieldName>
                <requestFieldName>id</requestFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <!-- Toolbar -->
    <container name="listing_top">
        <argument name="data" xsi:type="array">
            <item name="config" xsi:type="array">
                <item name="template" xsi:type="string">ui/grid/toolbar</item>
            </item>
        </argument>
        <bookmark name="bookmarks"/>
        <exportButton name="export_button"/>
        <filters name="listing_filters"/>
		<massaction name="listing_massaction">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="selectProvider" xsi:type="string">
						retailinsights_dtdccustom_processeddtdcorderslist_listing.retailinsights_dtdccustom_processeddtdcorderslist_listing.retailinsights_dtdccustom_processeddtdcorderslist_columns.ids
					</item>
					<item name="component" xsi:type="string">Magento_Ui/js/grid/tree-massactions</item>
					<item name="indexField" xsi:type="string">id</item>
				</item>
			</argument>

			<!-- Change to Delivered -->
			<action name="change_to_delivered">
				<argument name="data" xsi:type="array">
					<item name="config" xsi:type="array">
						<item name="type" xsi:type="string">delivered</item>
						<item name="label" xsi:type="string" translate="true">Change to Delivered</item>
						<item name="url" xsi:type="url" path="dtdccustom/processeddtdcorderslist/delivered"/>
						<item name="paramName" xsi:type="string">status</item>
					</item>
				</argument>
			</action>

			<!-- Change to Not Delivered -->
			<action name="change_to_not_delivered">
				<argument name="data" xsi:type="array">
					<item name="config" xsi:type="array">
						<item name="type" xsi:type="string">not_delivered</item>
						<item name="label" xsi:type="string" translate="true">Change to Not Delivered</item>
						<item name="url" xsi:type="url" path="dtdccustom/processeddtdcorderslist/notdelivered"/>
						<item name="paramName" xsi:type="string">status</item>
					</item>
				</argument>
			</action>

		</massaction>

        <paging name="listing_paging"/>
    </container>

    <!-- Columns -->
    <columns name="retailinsights_dtdccustom_processeddtdcorderslist_columns">

        <selectionsColumn name="ids">
            <settings>
                <indexField>id</indexField>
            </settings>
        </selectionsColumn>

        <!-- Order Number -->
        <column name="increment_id">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">textRange</item>
                    <item name="label" xsi:type="string" translate="true">Order #</item>
                </item>
            </argument>
        </column>

        <!-- Customer Info -->
        <column name="billing_name">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="sorting" xsi:type="string">asc</item>
                    <item name="label" xsi:type="string" translate="true">Bill To</item>
                </item>
            </argument>
        </column>

        <column name="student_name">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="sorting" xsi:type="string">asc</item>
                    <item name="label" xsi:type="string" translate="true">Student Name</item>
                </item>
            </argument>
        </column>

        <column name="roll_no">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="sorting" xsi:type="string">asc</item>
                    <item name="label" xsi:type="string" translate="true">Student Number</item>
                </item>
            </argument>
        </column>

        <column name="school_name">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="sorting" xsi:type="string">asc</item>
                    <item name="label" xsi:type="string" translate="true">School Name</item>
                </item>
            </argument>
        </column>

        <column name="school_code">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="sorting" xsi:type="string">asc</item>
                    <item name="label" xsi:type="string" translate="true">School Code</item>
                </item>
            </argument>
        </column>

        <!-- Contact -->
        <column name="customer_email">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="sorting" xsi:type="string">asc</item>
                    <item name="label" xsi:type="string" translate="true">Customer Email</item>
                </item>
            </argument>
        </column>

        <column name="telephone">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="sorting" xsi:type="string">asc</item>
                    <item name="label" xsi:type="string" translate="true">Phone</item>
                </item>
            </argument>
        </column>

        <column name="postcode">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="sorting" xsi:type="string">asc</item>
                    <item name="label" xsi:type="string" translate="true">Pincode</item>
                </item>
            </argument>
        </column>

        <!-- Payment & Amount -->
        <column name="payment_method">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="sorting" xsi:type="string">asc</item>
                    <item name="label" xsi:type="string" translate="true">Payment Method</item>
                </item>
            </argument>
        </column>

        <column name="base_grand_total">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="sorting" xsi:type="string">asc</item>
                    <item name="label" xsi:type="string" translate="true">Grand Total</item>
                </item>
            </argument>
        </column>

        <!-- Courier -->
        <column name="tracking_title" component="Magento_Ui/js/grid/columns/select">
			<settings>
				<filter>select</filter>
				<label translate="true">Courier Name</label>
				<dataType>select</dataType>
				<dataScope>tracking_title</dataScope>

				<options>
					<option name="1" xsi:type="array">
						<item name="value" xsi:type="string">DTDC</item>
						<item name="label" xsi:type="string">DTDC</item>
					</option>
					<option name="2" xsi:type="array">
						<item name="value" xsi:type="string">DELHIVERY</item>
						<item name="label" xsi:type="string">Delhivery</item>
					</option>
					<option name="3" xsi:type="array">
						<item name="value" xsi:type="string">ELASTICRUN</item>
						<item name="label" xsi:type="string">Elasticrun</item>
					</option>
					<option name="4" xsi:type="array">
						<item name="value" xsi:type="string">AMAZON</item>
						<item name="label" xsi:type="string">Amazon</item>
					</option>
					<option name="5" xsi:type="array">
						<item name="value" xsi:type="string">SMCS</item>
						<item name="label" xsi:type="string">SMCS</item>
					</option>
				</options>
			</settings>
		</column>




        <column name="tracking_number">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="sorting" xsi:type="string">asc</item>
                    <item name="label" xsi:type="string" translate="true">Tracking Number</item>
                </item>
            </argument>
        </column>

        <!-- Status -->
         <column name="status" component="Magento_Ui/js/grid/columns/select">
				<settings>
					<filter>select</filter>
					<label translate="true">Status</label>
					<dataType>select</dataType>
					<dataScope>status</dataScope>

					<options>
						<option name="1" xsi:type="array">
							<item name="value" xsi:type="string">order_delivered</item>
							<item name="label" xsi:type="string">Delivered</item>
						</option>
						<option name="2" xsi:type="array">
							<item name="value" xsi:type="string">order_not_delivered</item>
							<item name="label" xsi:type="string">Order Not Delivered</item>
						</option>
						<option name="3" xsi:type="array">
							<item name="value" xsi:type="string">dispatched_to_courier</item>
							<item name="label" xsi:type="string">Dispatched To Courier</item>
						</option>
					</options>
				</settings>
			</column>

        <!-- Date -->
        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date"
                component="Magento_Ui/js/grid/columns/date">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">dateRange</item>
                    <item name="editor" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Dispatched On</item>
                    <item name="sortOrder" xsi:type="number">60</item>
                </item>
            </argument>
        </column>

    </columns>
</listing>
