<?xml version="1.0" ?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
	<argument name="data" xsi:type="array">
		<item name="js_config" xsi:type="array">
			<item name="provider" xsi:type="string">retailinsights_courieravailability_courier_form.courier_form_data_source</item>
		</item>
		<item name="label" xsi:type="string" translate="true">General Information</item>
		<item name="template" xsi:type="string">templates/form/collapsible</item>
	</argument>
	<settings>
		<buttons>
			<button name="back" class="Retailinsights\CourierAvailability\Block\Adminhtml\Courier\Edit\BackButton"/>
			<button name="delete" class="Retailinsights\CourierAvailability\Block\Adminhtml\Courier\Edit\DeleteButton"/>
			<button name="save" class="Retailinsights\CourierAvailability\Block\Adminhtml\Courier\Edit\SaveButton"/>
			<button name="save_and_continue" class="Retailinsights\CourierAvailability\Block\Adminhtml\Courier\Edit\SaveAndContinueButton"/>
		</buttons>
		<namespace>retailinsights_courieravailability_courier_form</namespace>
		<dataScope>data</dataScope>
		<deps>
			<dep>retailinsights_courieravailability_courier_form.courier_form_data_source</dep>
		</deps>
	</settings>
	<dataSource name="courier_form_data_source">
		<argument name="data" xsi:type="array">
			<item name="js_config" xsi:type="array">
				<item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
			</item>
		</argument>
		<settings>
			<submitUrl path="*/*/save"/>
		</settings>
		<dataProvider name="courier_form_data_source" class="Retailinsights\CourierAvailability\Model\Courier\DataProvider">
			<settings>
				<requestFieldName>courier_id</requestFieldName>
				<primaryFieldName>courier_id</primaryFieldName>
			</settings>
		</dataProvider>
	</dataSource>
	<fieldset name="general">
		<settings>
			<label>General</label>
		</settings>
		<field name="courier_name" formElement="textarea" sortOrder="10">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">Courier</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">Courier Name</label>
				<dataScope>courier_name</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">false</rule>
				</validation>
			</settings>
		</field>

		<field name="pincode" formElement="input" sortOrder="20">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Pincode</label>
                <dataScope>pincode</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>

        <field name="is_available" formElement="select" sortOrder="30">
			<settings>
				<dataType>select</dataType>
				<label translate="true">Available</label>
				<dataScope>is_available</dataScope>
			</settings>
			<formElements>
				<select>
					<settings>
						<options class="Magento\Config\Model\Config\Source\Yesno"/>
					</settings>
				</select>
			</formElements>
		</field>

	</fieldset>
</form>
