            <td>&nbsp;</td>
            <td>&nbsp;</td>
            <td>&nbsp;</td>
            <td>&nbsp;</td>
            <td>&nbsp;</td>
            <td class="last">&nbsp;</td>
        </tr>
            </tbody>
             <?php } else {?>
                <tbody class="<?= /* @noEscape */ $i%2 ? 'even ' : 'odd' ?>">
                <?= $block->getItemHtml($_item) ?>
                <?= $block->getItemExtraInfoHtml($_item) ?>
            </tbody>
             <?php } ?>

        <?php endforeach; ?>
    </table>
</div>
