                continue;
            } else {
                $i++;
            }?>

            <?php if($block->isBackorder($_item)) { ?>      
            <tbody class="<?= /* @noEscape */ $i%2 ? 'even ' : 'odd' ?> <?= ($block->isBackorder($_item)) ? 'beckorder' : '' ?>">
                <?= $block->getItemHtml($_item) ?>
                <?= $block->getItemExtraInfoHtml($_item) ?>
                <tr>
            <td style="color: red;" class="col-product"><div class="option-label"><?php echo $this->helper('\Retailinsights\Backorders\Helper\Data')->getBackOrderMessage('admin_text'); ?></div></td>
