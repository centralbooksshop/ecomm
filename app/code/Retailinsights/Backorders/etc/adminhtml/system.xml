<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="retailinsights" translate="label" sortOrder="10">
            <label>Retail Insights</label>
        </tab>
        <section id="backorder" translate="label" sortOrder="130" showInDefault="1" showInWebsite="1" showInStore="1">
            <class>separator-top</class>
            <label>Backorder</label>
            <tab>retailinsights</tab>
            <resource>Retailinsights_Backorder::backorder_config</resource>
            <group id="general" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                <label>General Configuration</label>
                <field id="enable" translate="label" type="select" sortOrder="1" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Module Enable</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="admin_text" translate="label" type="text" sortOrder="2" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Back Admin Order View Message</label>
                    <comment>Default admin side message</comment>
                </field>
                <field id="email_text" translate="label" type="text" sortOrder="3" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Back Order EMail Message</label>
                    <comment>Default Email message</comment>
                </field>
                <field id="customer_text" translate="label" type="text" sortOrder="4" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Customer Order View Message</label>
                    <comment>Default customer message</comment>
                </field>
                <field id="confirmation_text" translate="label" type="text" sortOrder="5" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Confirmation Order Message</label>
                    <comment>Default confirmation message</comment>
                </field>
            </group>
        </section>
    </system>
</config>