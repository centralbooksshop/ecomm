<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd"
         name="retailinsights_willbegivenitems_list">

    <!-- JS Configuration -->
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">retailinsights_willbegivenitems_list.retailinsights_willbegivenitems_list_data_source</item>
            <item name="deps" xsi:type="string">retailinsights_willbegivenitems_list.retailinsights_willbegivenitems_list_data_source</item>
        </item>
        <item name="spinner" xsi:type="string">retailinsights_orders_willbegivenitems_columns</item>
    </argument>

    <!-- Data Source -->
	<dataSource name="retailinsights_willbegivenitems_list_data_source" component="Magento_Ui/js/grid/provider">
		<settings>
			<updateUrl path="mui/index/render"/>
			<filterUrlParams>
				<param name="name">*</param>
				<param name="given_options">*</param>
				<param name="product_purchased">*</param>
				<param name="dispatch_date">*</param>
				<param name="delivery_date">*</param>
				<param name="delivery_status">*</param>
				<param name="dispatch_status">*</param>
				<!-- <param name="is_delivery_confirmed">*</param> -->

			</filterUrlParams>
			<storageConfig>
				<param name="indexField" xsi:type="string">item_id</param>
			</storageConfig>
		</settings>
	
		<dataProvider name="retailinsights_willbegivenitems_list_data_source"
					  class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider">
			<argument name="collection" xsi:type="object">Retailinsights\Orders\Model\ResourceModel\Order\Item\Details\Collection</argument>
		    
			<settings>
				<primaryFieldName>item_id</primaryFieldName>
				<requestFieldName>item_id</requestFieldName>
			</settings>
		</dataProvider>
	</dataSource>

