<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
	<dataSource name="sales_order_grid_data_source" component="Magento_Ui/js/grid/provider">
		<settings>
			<updateUrl path="mui/index/render"/>
			<filterUrlParams>
				<param name="created_at">*</param>
			</filterUrlParams>
		</settings>
	</dataSource>
	
	<listingToolbar name="listing_top">
	        <exportButton name="export_button" class="Retailinsights\Orders\Ui\Component\ExportButton"/>
            <massaction name="listing_massaction">
                <action name="retailinsights_admin_bulkship">
                    <settings>
                        <url path="retailinsights_admin/index/bulkship"/>
                        <type>retailinsights_admin_bulkship</type>
                        <label translate="true">BulkShip with CBO Shipment</label>
                    </settings>
                </action>

				<action name="retailinsights_admin_massPrintThermal">
                    <settings>
                        <url path="retailinsights_admin/orders/massPrintThermal"/>
                        <type>retailinsights_admin_massPrintThermal</type>
                        <label translate="true">Print Picking Slip</label>
                    </settings>
                </action>
            </massaction>
    </listingToolbar>

    <columns name="sales_order_columns">
        
		<column name="dispatched_on" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
		  <settings>
			<filter>dateRange</filter>
			<dataType>date</dataType>
			<label translate="true">Dispatched Date</label>
			<sorting>desc</sorting>
		  </settings>
		</column>


		<!-- <column name="tracking_number">
		            <argument name="data" xsi:type="array">
		                <item name="config" xsi:type="array">
		                    <item name="filter" xsi:type="string">text</item>
		                    <item name="label" xsi:type="string" translate="true">Tracking Number</item>
		                </item>
		            </argument>
		        </column> -->

		
		<column name="student_name">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Student Name</item>
                </item>
            </argument>
        </column>
        <column name="roll_no">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Roll Number</item>
                </item>
            </argument>
        </column>
        <column name="telephone">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Phone Number</item>
                    <item name="sortOrder" xsi:type="number">2</item>
                </item>
            </argument>
        </column>
        <column name="entity_id">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Order Id</item>
					<item name="resizeEnabled" xsi:type="boolean">false</item>
                    <item name="resizeDefaultWidth" xsi:type="string">70</item>
                    <item name="sortOrder" xsi:type="number">1</item>
                </item>
            </argument>
        </column>

		<!-- <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="filter" xsi:type="string">dateRange</item>
					<item name="dataType" xsi:type="string">date</item>
					<item name="label" xsi:type="string" translate="true">Purchase Date</item>
					<item name="sorting" xsi:type="string">desc</item>
					<item name="filter_index" xsi:type="string">main_table.created_at</item>
				</item>
			</argument>
		</column> -->

		<column name="increment_id">
            <settings>
                <filter>text</filter>
                <label translate="true">Increment Id</label>
            </settings>
        </column>

		<column name="parent_split_order">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Split Parent Order Id</item>
                    <item name="sortOrder" xsi:type="number">3</item>
                </item>
            </argument>
        </column>
        <column name="school_name">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">School Name</item>
                </item>
            </argument>
        </column>
        <column name="school_code">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">School Code</item>
                </item>
            </argument>
        </column>

		<column name="location_code">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Location Code</item>
                </item>
            </argument>
        </column>

		<column name="schoolhub_name">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">School Hub</item>
                </item>
            </argument>
        </column>

		
        <column name="product_purchased">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="bodyTmpl" xsi:type="string">ui/grid/cells/html</item>
                    <item name="filter" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Product Purchased</item>
                </item>
            </argument>
        </column>
        <!-- <column name="sku">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="bodyTmpl" xsi:type="string">ui/grid/cells/html</item>
                    <item name="filter" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">SKU</item>
                </item>
            </argument>
        </column> -->
        <column name="trackingColumn">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="bodyTmpl" xsi:type="string">ui/grid/cells/html</item>
                    <item name="label" xsi:type="string" translate="true">Tracking Numbers</item>
                </item>
            </argument>
        </column>
        <column name="is_backeordered_items">
				<argument name="data" xsi:type="array">
						<item name="config" xsi:type="array">
							<item name="filter" xsi:type="string">text</item>
							<item name="sorting" xsi:type="string">asc</item>
							<item name="label" xsi:type="string" translate="true">Back Order Status</item>
						</item>
					</argument>
			</column>

		<column name="postcode">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Postcode</item>
					 <item name="sortOrder" xsi:type="number">29</item>
                </item>
            </argument>
        </column>
		
		<column name="zone">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Zone</item>
                </item>
            </argument>
        </column>



		<column name="web_invoice_number" sortOrder="200" class="Magento\Ui\Component\Listing\Columns\Column">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="label" xsi:type="string" translate="true">Web Invoice Number</item>
					<item name="filter" xsi:type="string">text</item>
					<item name="sorting" xsi:type="string">asc</item>
				</item>
			</argument>
		</column>

		<column name="courier_available">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="label" xsi:type="string" translate="true">Courier Available</item>
                    <item name="filter" xsi:type="string">text</item>
                    <item name="sorting" xsi:type="string">asc</item>
                    <item name="sortOrder" xsi:type="number">250</item>
                    <item name="visible" xsi:type="boolean">true</item>
                </item>
            </argument>
        </column>

		<column name="weight" sortOrder="250">
			<settings>
				<filter>text</filter>
				<label translate="true">Weight</label>
				<visible>true</visible>
				<sorting>asc</sorting>
			</settings>
		</column>


		<!-- <column name="shipsy_reference_numbers" class="Shipsy\EcommerceExtension\Ui\Component\Listing\Column\ReferenceNumbers">
		            <argument name="data" xsi:type="array">
		                <item name="config" xsi:type="array">
		                    <item name="bodyTmpl" xsi:type="string">ui/grid/cells/html</item>
		                    <item name="visible" xsi:type="boolean">true</item>
		                    <item name="label" xsi:type="string" translate="true">Reference Number</item>
		                    <item name="disableAction" xsi:type="boolean">true</item>
		                    <item name="filter" xsi:type="string">text</item>
		                </item>
		            </argument>
		        </column> -->
        <column name="shipsy_tracking_url" class="Shipsy\EcommerceExtension\Ui\Component\Listing\Column\TrackingUrl">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="bodyTmpl" xsi:type="string">ui/grid/cells/html</item>
                    <item name="visible" xsi:type="boolean">true</item>
                    <item name="label" xsi:type="string" translate="true">Tracking URL</item>
                    <item name="disableAction" xsi:type="boolean">true</item>
                    <item name="filter" xsi:type="string">text</item>
                </item>
            </argument>
        </column> 

        <actionsColumn  name="export_status" class="Retailinsights\Orders\Ui\Component\Listing\Column\OrderDetails">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="bodyTmpl" xsi:type="string">ui/grid/cells/html</item>
                    <!-- <item name="filter" xsi:type="string">text</item> -->                    
                    <item name="label" xsi:type="string" translate="true">Shipment Details</item>
                    <item name="sortOrder" xsi:type="number">30</item>
        
                </item>
            </argument>
        </actionsColumn>

    </columns>
</listing>