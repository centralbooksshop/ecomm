<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="customer_account"/>
    <head>
        <css src="Plumrocket_RMA::css/prrma.css" />
    </head>
    <body>
        <referenceContainer name="columns.top">
            <referenceContainer name="page.main.title">
                <block class="Plumrocket\RMA\Block\Returns\Template" name="rma.returns.history.buttons" template="Plumrocket_RMA::returns/history/buttons.phtml"/>
            </referenceContainer>
        </referenceContainer>
        <referenceContainer name="content">
            <block class="Plumrocket\RMA\Block\Returns\History" name="rma.returns.history" cacheable="false">
                <container name="rma.returns.history.info" as="info" label="Returns List Info"/>
            </block>
            <block class="Magento\Customer\Block\Account\Dashboard" name="customer.account.link.back" template="account/link/back.phtml" cacheable="false"/>
        </referenceContainer>
    </body>
</page>
