<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="customer_account"/>
    <head>
        <css src="Plumrocket_RMA::css/prrma.css" />
    </head>
    <body>
        <referenceContainer name="content">
            <container name="rma.returns.container.success">
                <block class="Plumrocket\RMA\Block\Returns\Template" name="rma.returns.success" template="Plumrocket_RMA::returns/create/success.phtml" cacheable="false" />
            </container>
            <block class="Magento\Customer\Block\Account\Dashboard" name="customer.account.link.back" template="Magento_Customer::account/link/back.phtml" cacheable="false"/>
        </referenceContainer>
    </body>
</page>
