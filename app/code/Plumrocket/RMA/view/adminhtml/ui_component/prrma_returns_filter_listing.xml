    <dataSource name="prrma_returns_filter_listing_data_source">
        <argument name="dataProvider" xsi:type="configurableObject">
            <!-- <argument name="class" xsi:type="string">Plumrocket\RMA\Ui\DataProvider\Returns\ReturnsDataProvider</argument> -->
			<argument name="class" xsi:type="string">Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider</argument>
            <argument name="name" xsi:type="string">prrma_returns_filter_listing_data_source</argument>
            <argument name="primaryFieldName" xsi:type="string">main_table.entity_id</argument>
            <argument name="requestFieldName" xsi:type="string">id</argument>
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="component" xsi:type="string">Magento_Ui/js/grid/provider</item>
                    <item name="update_url" xsi:type="url" path="mui/index/render"/>
					<item name="filter_url_params" xsi:type="array">
						<item name="status" xsi:type="string">*</item>
						<item name="reason_id" xsi:type="string">*</item>
					</item>
                    <item name="storageConfig" xsi:type="array">
                        <item name="indexField" xsi:type="string">entity_id</item>
                    </item>
                </item>
            </argument>
        </argument>
    </dataSource>
    <listingToolbar name="listing_top">
