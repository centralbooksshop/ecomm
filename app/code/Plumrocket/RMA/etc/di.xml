    <preference for="Plumrocket\RMA\Api\Data\ReturnSearchResultsInterface" type="Magento\Framework\Api\SearchResults" />
    <preference for="Plumrocket\RMA\Api\ReturnRepositoryInterface" type="Plumrocket\RMA\Model\ReturnRepository" />
    <preference for="Plumrocket\RMA\Api\ReturnInterface" type="Plumrocket\RMA\Model\Returns" />
    <preference for="Plumrocket\RMA\Api\Data\ReturnInterface" type="Plumrocket\RMA\Model\Returns" />
