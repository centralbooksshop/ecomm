    <preference for="Plumrocket\RMA\Api\ReturnItemResolutionRepositoryInterface" type="Plumrocket\RMA\Model\ItemResolutionRepository" />
    <preference for="Plumrocket\RMA\Api\Data\ItemResolutionSearchResultInterface" type="Magento\Framework\Api\SearchResults" />
    <preference for="Plumrocket\RMA\Api\Data\ItemResolutionInterface" type="Plumrocket\RMA\Model\Resolution" />
    <preference for="Plumrocket\RMA\Api\ReturnItemConditionRepositoryInterface" type="Plumrocket\RMA\Model\ReturnConditionRepository" />
